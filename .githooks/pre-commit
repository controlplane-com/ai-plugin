#!/usr/bin/env bash
#
# Pre-commit hook for the ai-plugin repo. Runs the same content gate as CI
# (.github/workflows/checks.yml) so a broken commit fails locally instead of
# in CI.
#
# Tool mentions — fail if any MCP tool named in skills/rules/agents/commands
# is unknown to the registry or omits its toolset-profile marker.
#
# Enable once per clone with:
#   git config core.hooksPath .githooks

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

staged_match() {
  git diff --cached --name-only --diff-filter=ACMRD | grep -qE "$1"
}

# Run CI's content gate whenever plugin content is staged. Skips commits that
# touch only manifests, docs, or scripts.
if staged_match '^plugins/cpln/(skills|rules|agents|commands)/'; then
  if ! command -v node >/dev/null 2>&1; then
    echo "pre-commit: node is required to run scripts/check-tool-mentions.mjs" >&2
    exit 1
  fi
  node "$REPO_ROOT/scripts/check-tool-mentions.mjs"
fi
